# ✅ ENVIRONMENT VARIABLES TEMPLATE
# Location: .env.example
# 
# IMPORTANT: This is a TEMPLATE file with placeholder values
# 
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Fill in YOUR actual values (get from your providers)
# 3. NEVER commit .env to Git
# 4. Add .env to .gitignore if not already there
#
# ✅ This fixes Issue 6.1 (Credentials in Code)

# ════════════════════════════════════════════════════════════════════════════
# 🔓 SECURITY WARNING
# ════════════════════════════════════════════════════════════════════════════
# NEVER commit .env to Git repository
# NEVER share .env file with anyone
# NEVER post these values in public GitHub issues or comments
# 
# If credentials are exposed:
# 1. Immediately regenerate all keys in Supabase console
# 2. Regenerate Gmail app password
# 3. Update .env with new values
# 4. Redeploy application
# ════════════════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════════════════
# 🗄️  DATABASE CONFIGURATION (Supabase)
# ════════════════════════════════════════════════════════════════════════════

# Get these from Supabase console: Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ACTUAL_KEY_HERE

# PostgreSQL direct connection (from Supabase Database settings)
DB_HOST=db.YOUR_PROJECT_ID.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE

# ════════════════════════════════════════════════════════════════════════════
# 📧 EMAIL CONFIGURATION (Gmail)
# ════════════════════════════════════════════════════════════════════════════

# Use GMAIL APP PASSWORD, NOT your main Gmail password!
# Generate app password: https://myaccount.google.com/apppasswords
# 1. Select \"Mail\" and \"Windows Computer\"
# 2. You'll get a 16-digit password
# 3. Copy it WITHOUT spaces: abc defg hijk lmno → abcdefghijklmno

GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmno

# SMTP settings (standard Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ════════════════════════════════════════════════════════════════════════════
# 🤖 AI MODEL CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# Paths to model and artifacts (can be relative or absolute)
MODEL_PATH=./best_model.pth
ARTIFACTS_PATH=./artifacts.pkl

# BERT model name (from Hugging Face)
# This is the pre-trained WangchanBERTa model for Thai language
BERT_MODEL=airesearch/wangchanberta-base-att-spm-uncased

# Device: auto (use GPU if available), cuda (force GPU), cpu (force CPU)
DEVICE=auto

# Number of k-nearest neighbors for graph construction
KNN_NEIGHBORS=10

# Text preprocessing limits
MAX_TEXT_LENGTH=5000
MAX_TOKENS=256

# Prediction confidence threshold (0.0-1.0)
CONFIDENCE_THRESHOLD=0.5

# Model caching (recommended: true for production)
CACHE_MODEL=true

# Use GPU for inference if available
USE_GPU=true

# ════════════════════════════════════════════════════════════════════════════
# 🚀 APPLICATION CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode (true/false)
# IMPORTANT: Set to false in production!
DEBUG=false

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Feature flags
ENABLE_ADMIN=true
ENABLE_FEEDBACK=true
ENABLE_URL_SCRAPING=true

# ════════════════════════════════════════════════════════════════════════════
# 🛡️  RATE LIMITING & SECURITY
# ════════════════════════════════════════════════════════════════════════════

# Maximum predictions per minute per user
MAX_PREDICTIONS_PER_MINUTE=30

# Maximum predictions per hour per user
MAX_PREDICTIONS_PER_HOUR=500

# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=60

# ════════════════════════════════════════════════════════════════════════════
# 📊 MONITORING & ANALYTICS (Optional)
# ════════════════════════════════════════════════════════════════════════════

# Sentry (error tracking) - optional
SENTRY_DSN=

# Google Analytics - optional
GOOGLE_ANALYTICS_ID=

# ════════════════════════════════════════════════════════════════════════════
# 🐳 DOCKER CONFIGURATION (If using Docker)
# ════════════════════════════════════════════════════════════════════════════

# Port to expose Streamlit on
STREAMLIT_PORT=8501

# Docker image name
DOCKER_IMAGE_NAME=truecheck-ai

# Docker registry (if pushing to registry)
DOCKER_REGISTRY=docker.io

# ════════════════════════════════════════════════════════════════════════════
# ✅ SETUP CHECKLIST
# ════════════════════════════════════════════════════════════════════════════
# 
# Before running the application:
# 
# [ ] 1. Get Supabase credentials:
#       - Go to https://app.supabase.com
#       - Create project or select existing
#       - Go to Project Settings > API
#       - Copy SUPABASE_URL and SUPABASE_KEY
#
# [ ] 2. Get Gmail app password:
#       - Go to https://myaccount.google.com/apppasswords
#       - Select Mail and Windows Computer
#       - Copy the 16-digit password
#
# [ ] 3. Get database credentials:
#       - In Supabase console: Project Settings > Database
#       - Copy connection details
#
# [ ] 4. Verify model files exist:
#       - best_model.pth in project root
#       - artifacts.pkl in project root
#
# [ ] 5. Copy this file and fill in values:
#       cp .env.example .env
#       # Edit .env with your actual credentials
#
# [ ] 6. Verify .env is in .gitignore
#
# [ ] 7. Test configuration:
#       python -c \"from config import config; print('✅ Config OK')\"
#
# [ ] 8. Run application:
#       streamlit run streamlit_app/app.py
#
# ════════════════════════════════════════════════════════════════════════════
